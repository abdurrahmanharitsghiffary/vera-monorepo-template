{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@vera-monorepo/source"],
    "rootDir": ".",
    "paths": {
      "@vera/web-ui": ["./libs/web/ui/src/lib"],
      "@vera/web-ui/*": ["./libs/web/ui/src/lib/*"],
      "@vera/web-styles/*": ["./libs/web/ui/src/styles/*"],
      "@vera/common-utils": ["./libs/utils/src/lib"],
      "@vera/common-utils/*": ["./libs/utils/src/lib/*"],
      "@vera/react-hooks": ["./libs/web/hooks/src/lib"],
      "@vera/react-hooks/*": ["./libs/web/hooks/src/lib/*"],
      "@vera/web-lib": ["./libs/web/lib/src/lib"],
      "@vera/web-lib/*": ["./libs/web/lib/src/lib/*"]
    }
  }
}
